# Keep the build context and image lean and secret-free.
node_modules
.next
out
build

# Secrets & local data — never copy into the image
.env
.env.*
data
*.sqlite
*.sqlite3
*.db
*.db-shm
*.db-wal

# VCS / tooling
.git
.gitignore
.claude
.vscode
.idea

# Tests (not needed in the runtime image)
src/**/*.test.ts
vitest.config.ts
vitest.setup.ts

# Docs & misc
README.md
SECURITY.md
*.heic
docs
npm-debug.log*
Dockerfile
.dockerignore
docker-compose.yml
